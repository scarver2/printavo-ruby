# .gitignore
*.gem
*.rbc
/.config
/coverage/
/InstalledFiles
/pkg/
/spec/reports/
/spec/examples.txt
/test/tmp/
/test/version_tmp/
/tmp/

# Cassettes with real data (sanitized cassettes ARE committed)
# spec/cassettes/

# Environment — never commit credentials
.env
.env.*
!.env.example

# Bundler
/.bundle/
/vendor/bundle

# Editor
.idea/
.vscode/
*.swp
*~
.DS_Store

# Coverage
/coverage/
